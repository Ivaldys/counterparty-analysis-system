#:kivy 2.2.1

<ProfileScreen>:
    name: "profile"

    canvas.before:
        Color:
            rgba: (0.95, 0.95, 0.97, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(24)

        Widget:
            size_hint_y: 1

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"

            FloatLayout:
                size_hint: None, None
                width: dp(520)
                height: card.height + dp(10)

                BoxLayout:
                    id: card
                    size_hint: None, None
                    width: dp(500)
                    height: self.minimum_height
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    orientation: "vertical"
                    padding: dp(22)
                    spacing: dp(12)

                    canvas.before:
                        Color:
                            rgba: (0, 0, 0, 0.10)
                        RoundedRectangle:
                            pos: (self.x, self.y - dp(4))
                            size: self.size
                            radius: [18]
                        Color:
                            rgba: (1, 1, 1, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [18]

                    Label:
                        text: "Личный кабинет"
                        color: (0.1, 0.1, 0.12, 1)
                        font_size: "28sp"
                        bold: True
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                    Label:
                        id: profile_msg
                        text: ""
                        color: (0.85, 0.20, 0.20, 1)
                        size_hint_y: None
                        height: self.texture_size[1] if self.text else 0
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                    Label:
                        id: profile_name
                        text: "ФИО: —"
                        color: (0.15, 0.15, 0.18, 1)
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        id: profile_email
                        text: "Почта: —"
                        color: (0.15, 0.15, 0.18, 1)
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        id: profile_phone
                        text: "Телефон: —"
                        color: (0.15, 0.15, 0.18, 1)
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        id: profile_company
                        text: "Компания: —"
                        color: (0.15, 0.15, 0.18, 1)
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        id: profile_inn
                        text: "ИНН компании: —"
                        color: (0.15, 0.15, 0.18, 1)
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        id: profile_verified
                        text: "Почта подтверждена: —"
                        color: (0.15, 0.15, 0.18, 1)
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: self.texture_size[1]

                    Button:
                        text: "Редактировать профиль"
                        size_hint_y: None
                        height: dp(46)
                        background_normal: ""
                        background_color: (0.10, 0.45, 0.90, 1)
                        color: (1, 1, 1, 1)
                        on_release: root.open_edit_popup()

                    Button:
                        text: "Сменить пароль"
                        size_hint_y: None
                        height: dp(46)
                        background_normal: ""
                        background_color: (0.90, 0.92, 0.96, 1)
                        color: (0.10, 0.10, 0.12, 1)
                        on_release: root.open_password_popup()

                    Button:
                        text: "Выйти из аккаунта"
                        size_hint_y: None
                        height: dp(46)
                        background_normal: ""
                        background_color: (0.85, 0.20, 0.20, 1)
                        color: (1, 1, 1, 1)
                        on_release: root.logout()

                    Button:
                        text: "Назад"
                        size_hint_y: None
                        height: dp(46)
                        background_normal: ""
                        background_color: (0.10, 0.45, 0.90, 1)
                        color: (1, 1, 1, 1)
                        on_release: root.manager.current = "home"

        Widget:
            size_hint_y: 1
<EditProfilePopup>:
    size_hint: None, None
    size: dp(560), dp(430)
    auto_dismiss: False
    background_color: (0, 0, 0, 0.35)

    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(14)

        canvas.before:
            Color:
                rgba: (1, 1, 1, 1)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [18]

        Label:
            text: "Редактирование профиля"
            color: (0.10, 0.10, 0.12, 1)
            font_size: "22sp"
            bold: True
            size_hint_y: None
            height: dp(30)

        GridLayout:
            cols: 2
            spacing: dp(10)
            size_hint_y: None
            height: self.minimum_height
            row_default_height: dp(42)
            row_force_default: True

            Label:
                text: "ФИО"
                color: (0.15, 0.15, 0.18, 1)
                halign: "left"
                valign: "middle"
                text_size: self.size

            TextInput:
                id: edit_full_name
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: (0.97, 0.97, 0.99, 1)
                foreground_color: (0.10, 0.10, 0.12, 1)

            Label:
                text: "Телефон"
                color: (0.15, 0.15, 0.18, 1)
                halign: "left"
                valign: "middle"
                text_size: self.size

            TextInput:
                id: edit_phone
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: (0.97, 0.97, 0.99, 1)
                foreground_color: (0.10, 0.10, 0.12, 1)

            Label:
                text: "Компания"
                color: (0.15, 0.15, 0.18, 1)
                halign: "left"
                valign: "middle"
                text_size: self.size

            TextInput:
                id: edit_company_name
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: (0.97, 0.97, 0.99, 1)
                foreground_color: (0.10, 0.10, 0.12, 1)

            Label:
                text: "ИНН компании"
                color: (0.15, 0.15, 0.18, 1)
                halign: "left"
                valign: "middle"
                text_size: self.size

            TextInput:
                id: edit_company_inn
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: (0.97, 0.97, 0.99, 1)
                foreground_color: (0.10, 0.10, 0.12, 1)

        Widget:

        BoxLayout:
            size_hint_y: None
            height: dp(48)
            spacing: dp(10)

            Button:
                text: "Отмена"
                background_normal: ""
                background_color: (0.90, 0.92, 0.96, 1)
                color: (0.10, 0.10, 0.12, 1)
                on_release: root.dismiss()

            Button:
                text: "Сохранить"
                background_normal: ""
                background_color: (0.10, 0.45, 0.90, 1)
                color: (1, 1, 1, 1)
                on_release:
                    app.root.get_screen("profile").save_profile(
                    edit_full_name.text,
                    edit_phone.text,
                    edit_company_name.text,
                    edit_company_inn.text,
                    root
                    )
<ChangePasswordPopup>:
    size_hint: None, None
    size: dp(560), dp(360)
    auto_dismiss: False
    background_color: (0, 0, 0, 0.35)

    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(14)

        canvas.before:
            Color:
                rgba: (1, 1, 1, 1)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [18]

        Label:
            text: "Смена пароля"
            color: (0.10, 0.10, 0.12, 1)
            font_size: "22sp"
            bold: True
            size_hint_y: None
            height: dp(30)

        GridLayout:
            cols: 2
            spacing: dp(10)
            size_hint_y: None
            height: self.minimum_height
            row_default_height: dp(42)
            row_force_default: True

            Label:
                text: "Текущий пароль"
                color: (0.15, 0.15, 0.18, 1)
                halign: "left"
                valign: "middle"
                text_size: self.size

            BoxLayout:
                size_hint_y: None
                height: dp(42)
                spacing: dp(6)

                TextInput:
                    id: old_password_input
                    multiline: False
                    password: True
                    background_normal: ""
                    background_active: ""
                    background_color: (0.97, 0.97, 0.99, 1)
                    foreground_color: (0.10, 0.10, 0.12, 1)

                Button:
                    text: "visibility_off"
                    font_name: "MaterialIcons"
                    size_hint_x: None
                    width: dp(48)
                    background_normal: ""
                    background_color: (0.97, 0.97, 0.99, 1)
                    color: (0.35, 0.35, 0.40, 1)
                    on_release:
                        old_password_input.password = not old_password_input.password
                        self.text = "visibility" if not old_password_input.password else "visibility_off"

            Label:
                text: "Новый пароль"
                color: (0.15, 0.15, 0.18, 1)
                halign: "left"
                valign: "middle"
                text_size: self.size

            BoxLayout:
                size_hint_y: None
                height: dp(42)
                spacing: dp(6)

                TextInput:
                    id: new_password_input
                    multiline: False
                    password: True
                    background_normal: ""
                    background_active: ""
                    background_color: (0.97, 0.97, 0.99, 1)
                    foreground_color: (0.10, 0.10, 0.12, 1)

                Button:
                    text: "visibility_off"
                    font_name: "MaterialIcons"
                    size_hint_x: None
                    width: dp(48)
                    background_normal: ""
                    background_color: (0.97, 0.97, 0.99, 1)
                    color: (0.35, 0.35, 0.40, 1)
                    on_release:
                        new_password_input.password = not new_password_input.password
                        self.text = "visibility" if not new_password_input.password else "visibility_off"

            Label:
                text: "Повторите пароль"
                color: (0.15, 0.15, 0.18, 1)
                halign: "left"
                valign: "middle"
                text_size: self.size

            BoxLayout:
                size_hint_y: None
                height: dp(42)
                spacing: dp(6)

                TextInput:
                    id: confirm_password_input
                    multiline: False
                    password: True
                    background_normal: ""
                    background_active: ""
                    background_color: (0.97, 0.97, 0.99, 1)
                    foreground_color: (0.10, 0.10, 0.12, 1)

                Button:
                    text: "visibility_off"
                    font_name: "MaterialIcons"
                    size_hint_x: None
                    width: dp(48)
                    background_normal: ""
                    background_color: (0.97, 0.97, 0.99, 1)
                    color: (0.35, 0.35, 0.40, 1)
                    on_release:
                        confirm_password_input.password = not confirm_password_input.password
                        self.text = "visibility" if not confirm_password_input.password else "visibility_off"

        Widget:

        BoxLayout:
            size_hint_y: None
            height: dp(48)
            spacing: dp(10)

            Button:
                text: "Отмена"
                background_normal: ""
                background_color: (0.90, 0.92, 0.96, 1)
                color: (0.10, 0.10, 0.12, 1)
                on_release: root.dismiss()

            Button:
                text: "Изменить пароль"
                background_normal: ""
                background_color: (0.10, 0.45, 0.90, 1)
                color: (1, 1, 1, 1)
                on_release:
                    app.root.get_screen("profile").change_password(
                    old_password_input.text,
                    new_password_input.text,
                    confirm_password_input.text,
                    root
                    )
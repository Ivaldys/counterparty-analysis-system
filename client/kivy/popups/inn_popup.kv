#:kivy 2.2.1

<InnDirectoryPopup>:
    size_hint: 1, 1
    auto_dismiss: False
    background_color: (0, 0, 0, 0.35)

    BoxLayout:
        orientation: "vertical"
        padding: dp(40)

        Widget:
            size_hint_y: 0.08

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"

            FloatLayout:
                size_hint: None, None
                width: dp(1000)
                height: dp(620)

                BoxLayout:
                    size_hint: None, None
                    width: dp(980)
                    height: dp(600)
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    orientation: "vertical"
                    padding: dp(20)
                    spacing: dp(12)

                    canvas.before:
                        Color:
                            rgba: (0, 0, 0, 0.12)
                        RoundedRectangle:
                            pos: (self.x, self.y - dp(5))
                            size: self.size
                            radius: [20]
                        Color:
                            rgba: (1, 1, 1, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [20]

                    Label:
                        text: "Загрузка справочника ИНН"
                        color: (0.1, 0.1, 0.12, 1)
                        font_size: "24sp"
                        bold: True
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        id: inn_upload_msg
                        text: ""
                        color: (0.85, 0.2, 0.2, 1)
                        size_hint_y: None
                        height: self.texture_size[1] if self.text else 0

                    BoxLayout:
                        spacing: dp(12)

                        BoxLayout:
                            orientation: "vertical"
                            spacing: dp(8)
                            size_hint_x: 0.45

                            Label:
                                text: "Выберите файл справочника"
                                color: (0.25, 0.25, 0.28, 1)
                                size_hint_y: None
                                height: self.texture_size[1]
                                halign: "left"
                                text_size: self.size

                            BoxLayout:
                                padding: dp(6)

                                canvas.before:
                                    Color:
                                        rgba: (0.22, 0.24, 0.28, 1)
                                    RoundedRectangle:
                                        pos: self.pos
                                        size: self.size
                                        radius: [12]

                                FileChooserListView:
                                    id: inn_filechooser
                                    filters: ["*.csv", "*.xlsx", "*.xls"]
                                    path: "."
                                    on_selection: app.root.get_screen("home").preview_selected_inn_file(self.selection)

                        BoxLayout:
                            orientation: "vertical"
                            spacing: dp(8)
                            size_hint_x: 0.55

                            Label:
                                text: "Ожидаемый формат: Название | ИНН"
                                color: (0.25, 0.25, 0.28, 1)
                                size_hint_y: None
                                height: self.texture_size[1]
                                halign: "left"
                                text_size: self.size

                            ScrollView:
                                do_scroll_x: True
                                do_scroll_y: True
                                bar_width: dp(8)
                                scroll_type: ['bars', 'content']

                                GridLayout:
                                    id: inn_preview_table
                                    cols: 2
                                    size_hint: None, None
                                    width: self.minimum_width
                                    height: self.minimum_height
                                    row_default_height: dp(34)
                                    row_force_default: True
                                    col_default_width: dp(180)
                                    col_force_default: True
                                    spacing: dp(2)
                                    padding: dp(2)

                                    Label:
                                        text: "Название"
                                        bold: True
                                        color: (0.10, 0.10, 0.12, 1)
                                        size_hint: None, None
                                        size: dp(180), dp(36)

                                    Label:
                                        text: "ИНН"
                                        bold: True
                                        color: (0.10, 0.10, 0.12, 1)
                                        size_hint: None, None
                                        size: dp(180), dp(36)

                                    Label:
                                        text: "ООО Пример"
                                        color: (0.15, 0.15, 0.18, 1)
                                        size_hint: None, None
                                        size: dp(180), dp(34)

                                    Label:
                                        text: "7701234567"
                                        color: (0.15, 0.15, 0.18, 1)
                                        size_hint: None, None
                                        size: dp(180), dp(34)

                    BoxLayout:
                        size_hint_y: None
                        height: dp(48)
                        spacing: dp(10)

                        Button:
                            text: "Назад"
                            background_normal: ""
                            background_color: (0.90, 0.92, 0.96, 1)
                            color: (0.10, 0.10, 0.12, 1)
                            on_release: root.dismiss()

                        Button:
                            text: "Подтвердить справочник"
                            background_normal: ""
                            background_color: (0.10, 0.45, 0.90, 1)
                            color: (1, 1, 1, 1)
                            on_release:
                                app.root.get_screen("home").confirm_inn_file(
                                inn_filechooser.selection,
                                root
                                )